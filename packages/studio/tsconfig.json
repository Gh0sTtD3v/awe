{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": "./src",
    "paths": {
      "@oncyberio/engine": ["../../engine/src/index.ts"],
      "@oncyberio/engine/*": ["../../engine/src/*"],
      "@oncyberio/engine-edit": ["../../engine-edit/src/index.ts"],
      "@oncyberio/engine-edit/*": ["../../engine-edit/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js"
  ],
  "exclude": ["node_modules"]
}
