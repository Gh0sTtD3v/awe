{
  "name": "@oncyberio/engine",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./headless": "./src/engine-headless.ts",
    "./controls": "./src/controls/index.ts",
    "./input": "./src/input/index.ts",
    "./internal": "./src/internal.ts",
    "./space": "./src/space/index.ts",
    "./space/gui-types": "./src/space/gui-types.ts",
    "./*": "./src/*",
    "./internal/resources/loaders/draco-loader": {
      "browser": "./src/internal/resources/loaders/web-draco-loader.js",
      "node": "./src/internal/resources/loaders/node-draco-loader.js",
      "default": "./src/internal/resources/loaders/web-draco-loader.js"
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build:api": "tsc -p tsconfig.api.json; tsc-alias -p tsconfig.api.json; node scripts/post-build-api.mjs",
    "test": "vitest run",
    "headless:check": "tsx --import tsconfig-paths/register scripts/headless-check.ts"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.11.2",
    "@pixiv/three-vrm": "^2.0.6",
    "@pixiv/three-vrm-springbone": "^2.0.6",
    "@recast-navigation/core": "^0.38.0",
    "@recast-navigation/three": "^0.38.0",
    "dat.gui": "^0.7.9",
    "detect-gpu": "^5.0.37",
    "gsap": "^3.12.2",
    "postprocessing": "^6.38.0",
    "react": "^18",
    "react-dom": "^18",
    "recast-navigation": "^0.38.0",
    "simplex-noise": "^2.4.0",
    "spectorjs": "^0.9.29",
    "stats.js": "^0.17.0",
    "three": "^0.170.0",
    "three.quarks": "^0.15.0"
  },
  "peerDependencies": {
    "@dimforge/rapier3d": "0.11.2",
    "draco3dgltf": "^1.5.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/three": "^0.170.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "LICENCE"
  ]
}
