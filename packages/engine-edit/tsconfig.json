{
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "target": "ES2022",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": false,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "baseUrl": "./src",
        "paths": {
            "@oncyberio/engine": ["../../engine/src/index.ts"],
            "@oncyberio/engine/*": ["../../engine/src/*"]
        }
    },
    "include": [
        "src/**/*.js",
        "src/**/*.ts",
        "src/**/*.tsx",
    ],
    "exclude": ["node_modules"]
}
