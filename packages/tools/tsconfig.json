{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "target": "ES2022",
    "lib": ["dom", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "baseUrl": "./src"
  },
  "include": [
    "src/**/*.js",
    "src/**/*.ts",
    "examples/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
