{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "./dist/server",
    "rootDir": "."
  },
  "include": ["server/**/*.ts", "shared/**/*.ts"]
}
